# =========================================================================
# KONFIGURASI SOAR DASHBOARD
# =========================================================================
# Copy file ini menjadi .env, lalu sesuaikan IP dan konfigurasi sesuai VPS Anda.

# IP VPN dari Victim Node (VPS A / Honeypot) tempat aksi mitigasi akan dijalankan
VICTIM_VPN_IP="100.x.x.x"

# Username di Victim Node (umumnya 'root' jika di VPS, atau user lain yang punya NOPASSWD sudo)
VICTIM_USER="root"

# Path ke private key SSH yang telah didaftarkan di authorized_keys Victim Node
SSH_KEY_PATH="~/.ssh/id_rsa"
